{
  "name": "forge-dev",
  "repository": "https://github.com/HenryD11703/Forge",
  "displayName": "Forge - Learn to Code",
  "description": "Forja tu carrera como desarrollador. Aprende HTML, CSS, JavaScript y Git con ejercicios guiados y evaluación con IA.",
  "version": "1.1.2",
  "publisher": "HenryDavidQuel",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "html",
    "css",
    "javascript",
    "git",
    "aprender",
    "forge",
    "dev"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forge-sidebar",
          "title": "Forge",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "forge-sidebar": [
        {
          "type": "webview",
          "id": "forge.mainView",
          "name": "Misiones"
        }
      ]
    },
    "commands": [
      {
        "command": "forge.start",
        "title": "Forge: Inicio"
      },
      {
        "command": "forge.resetProgress",
        "title": "Forge: Reiniciar Progreso"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}